# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/purgeq
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# API
API_KEY_HEADER=X-API-Key
DEBUG=false
ALLOWED_ORIGINS=["*"]

# ----- Self-hosted mode (default) -----
# Static keys live here. Each entry grants full access to the single global
# banlist. Set this to a long random secret in production.
VALID_API_KEYS=["change-me-to-a-long-random-string"]

# ----- Public-hosted (multi-tenant) mode -----
# Flip to true to run the public-facing service. Each Discord login then
# creates or rotates an API key scoped to its own private banlist.
MULTI_TENANT=false

# Required when MULTI_TENANT=true. Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_PEPPER=

# Discord OAuth credentials (https://discord.com/developers/applications)
# Add the redirect URI below to the app's OAuth2 settings on Discord too.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-domain.example.com/auth/discord/callback
PUBLIC_BASE_URL=https://your-domain.example.com
