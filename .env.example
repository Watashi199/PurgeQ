# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/purgeq
DB_ECHO=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# API Configuration
API_V1_STR=/api/v1
API_TITLE=PurgeQ FACEIT Banlist API
API_VERSION=1.0.0
API_KEY_HEADER=X-API-Key
VALID_API_KEYS=["your-api-key-1","your-api-key-2","your-api-key-3"]
DEBUG=false

# CORS
ALLOWED_ORIGINS=*

# Validation
FACEIT_NAME_MIN_LENGTH=2
FACEIT_NAME_MAX_LENGTH=32
REASON_MIN_LENGTH=1
REASON_MAX_LENGTH=250
AUTHOR_MIN_LENGTH=2
AUTHOR_MAX_LENGTH=32

# Extension API URL
REACT_APP_API_URL=https://api.example.com
