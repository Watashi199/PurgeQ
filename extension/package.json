{
  "name": "purgeq-extension",
  "version": "2.1.2",
  "description": "PurgeQ Chrome/Firefox extension for FACEIT banlist",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "npm run build && node scripts/zip-dist.js",
    "package:firefox": "npm run build && node scripts/zip-dist.js --firefox",
    "package:source": "node scripts/zip-source.js",
    "icons": "node scripts/svg-to-icons.js",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "vite": "^7.3.3"
  }
}
